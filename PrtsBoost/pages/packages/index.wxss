/* 套餐页样式 */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #f5f5f5;
}

.page-header {
  padding: 24rpx 32rpx 8rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.page-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

/* 套餐滚动区域 */
.pkg-scroll {
  flex: 1;
  height: 0;
  padding-top: 8rpx;
}

/* 套餐卡片 */
.pkg-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.pkg-card-selected {
  border-color: #E54545;
  background: #FFFBFB;
}

.pkg-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.pkg-name-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  min-width: 0;
}

.pkg-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.4;
}

.pkg-selected-tag {
  font-size: 20rpx;
  color: #E54545;
  background: #FFF0F0;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.pkg-content-wrap,
.pkg-req-wrap {
  display: flex;
  margin-bottom: 12rpx;
}

.pkg-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
  flex-shrink: 0;
  width: 52rpx;
}

.pkg-content,
.pkg-req {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  flex: 1;
  min-width: 0;
}

.pkg-req {
  color: #E5A100;
}

/* 价格区 */
.pkg-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
  flex-wrap: wrap;
}

.pkg-price-wrap {
  display: flex;
  align-items: baseline;
}

.pkg-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #E54545;
}

.pkg-price-original {
  font-size: 24rpx;
  color: #ccc;
  text-decoration: line-through;
  margin-left: 8rpx;
}

/* 变体选择 */
.pkg-variant {
  display: flex;
  margin-top: 12rpx;
  width: 100%;
  gap: 12rpx;
}

.pkg-variant-opt {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.pkg-variant-active {
  color: #E54545;
  background: #FFF0F0;
  border-color: #E54545;
}
