/* 总览页样式 */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: transparent;
}

.page-header {
  padding: 24rpx 32rpx 8rpx;
}

.page-title-row {
  display: flex;
  align-items: center;
}

.page-title-img {
  height: 44rpx;
  width: auto;
  margin-right: 12rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.page-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

/* 滚动区域 */
.ov-scroll {
  flex: 1;
  height: 0;
  padding-top: 8rpx;
}

/* === 全包优惠行 === */
.ov-section {
  margin-bottom: 16rpx;
}

.ov-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.85);
  margin: 0 24rpx 2rpx;
  border-radius: 8rpx;
}

.ov-row:first-child {
  border-radius: 16rpx 16rpx 8rpx 8rpx;
}

.ov-row:last-child {
  border-radius: 8rpx 8rpx 16rpx 16rpx;
}

.ov-row:only-child {
  border-radius: 16rpx;
}

.ov-row-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.ov-row-category {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 2rpx;
}

.ov-row-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.ov-row-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.ov-row-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #E54545;
  margin-right: 16rpx;
}
