/* 单项页样式 */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #f5f5f5;
}

.page-header {
  padding: 24rpx 32rpx 8rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.page-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

/* 模块Tab栏 */
.tab-bar {
  display: flex;
  padding: 12rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  padding: 12rpx 36rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.2s;
}

.tab-active {
  color: #fff;
  background: #E54545;
}

/* 树形列表滚动区 */
.items-scroll {
  flex: 1;
  height: 0;
}

/* 空态 */
.items-empty {
  padding: 120rpx 0;
  text-align: center;
  color: #ccc;
  font-size: 28rpx;
}
