<!-- 单项页 — 三层树形结构 + 模块Tab -->
<view class="page-container">

  <!-- 全局背景 -->
  <image class="bg-image" src="/images/bg.jpg" mode="aspectFill" />

  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-title-row">
      <image class="page-title-img" src="/images/title.jpg" mode="heightFix" />
      <text class="page-title">PRTSBoost</text>
      <text class="page-version" wx:if="{{versionLabel}}">{{versionLabel}}</text>
    </view>
    <text class="page-subtitle">单项选择 · 按品类浏览</text>
  </view>

  <!-- 模块Tab栏 -->
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === 'task' ? 'tab-active' : ''}}"
      data-tab="task"
      bindtap="onTabChange"
    >
      <text>任务</text>
    </view>
    <view
      class="tab-item {{currentTab === 'explore' ? 'tab-active' : ''}}"
      data-tab="explore"
      bindtap="onTabChange"
    >
      <text>探索</text>
    </view>
    <view
      class="tab-item {{currentTab === 'infra' ? 'tab-active' : ''}}"
      data-tab="infra"
      bindtap="onTabChange"
    >
      <text>基建</text>
    </view>
    <view
      class="tab-item {{currentTab === 'new_content' ? 'tab-active' : ''}}"
      data-tab="new_content"
      bindtap="onTabChange"
    >
      <text>新增</text>
    </view>
  </view>

  <!-- 树形列表 -->
  <scroll-view class="items-scroll" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" bounces="{{false}}">
    <view wx:if="{{flatList.length > 0}}">
      <tree-node
        wx:for="{{flatList}}"
        wx:key="node.id"
        node="{{item.node}}"
        depth="{{item.depth}}"
        checkedIds="{{checkedIds}}"
        expandedIds="{{expandedIds}}"
        refreshStamp="{{refreshStamp}}"
        bind:toggle-check="onToggleCheck"
        bind:toggle-check-all="onToggleCheckAll"
        bind:toggle-expand="onToggleExpand"
        bind:quantity-change="onQuantityChange"
      />
    </view>

    <!-- 空态 -->
    <view class="items-empty" wx:else>
      <text>加载中...</text>
    </view>

    <!-- 底部占位 -->
    <view style="height: 160rpx;"></view>
  </scroll-view>

  <!-- 悬浮购物车按钮 -->
  <view class="float-cart-btn" bindtap="onCartBtnTap">
    <image class="fc-icon" src="/images/icons/goods.png" mode="aspectFit" />
    <view class="fc-badge" wx:if="{{cartCount > 0}}">
      <block wx:if="{{pkgCount > 0 && itemCount > 0}}">{{pkgCount}}+{{itemCount}}</block>
      <block wx:else>{{cartCount}}</block>
    </view>
  </view>

  <!-- 购物车弹窗 -->
  <cart-popup
    show="{{showCart}}"
    cartItems="{{cartItems}}"
    treeRoots="{{treeRoots}}"
    bind:close="onCartClose"
    bind:cart-changed="onCartChanged"
    bind:generate="onGenerateImage"
  />

  <!-- 图片预览 -->
  <image-preview
    show="{{showImagePreview}}"
    cartItems="{{cartItems}}"
    treeRoots="{{treeRoots}}"
    versionLabel="{{versionLabel}}"
    bind:close="onImagePreviewClose"
  />
</view>
