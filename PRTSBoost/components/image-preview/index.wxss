/* image-preview 组件样式 */

.ip-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.92);
  z-index: 300;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 固定关闭按钮 — 右上角 */
.ip-close-fixed {
  position: fixed;
  top: 0;
  right: 0;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 310;
}

.ip-close-fixed-x {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1;
}

.ip-close-fixed:active .ip-close-fixed-x {
  color: #fff;
}

.ip-scroll {
  width: 100%;
  flex: 1;
  height: 0;
  padding-top: 70rpx;
}

.ip-loading {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ip-loading-text {
  color: #fff;
  font-size: 28rpx;
}

.ip-image {
  width: 92%;
  margin: 0 4%;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.ip-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 24rpx;
  padding: 0 4%;
}

.ip-hint {
  color: #aaa;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.ip-close-btn {
  width: 200rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ip-close-btn:active {
  background: rgba(255, 255, 255, 0.3);
}

/* 隐藏的 Canvas（离屏渲染） */
.ip-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
}
